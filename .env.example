# --- SHARED (Global Secrets) ---
# Found in Supabase Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Standard Connection String for Quart/LangGraph
# Example: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_DIRECT_CONNECTION_URI=postgresql://user:password@host:port/dbname

# --- BACKEND (Quart) ---
# Generate a random string for session security (e.g., 'openssl rand -hex 32')
BACKEND_SECRET_KEY=your-super-secret-quart-key
# Internal Docker URL: http://langgraph-api:8000 | Local: http://127.0.0.1:2024
BACKEND_ASSISTANT_API_URL=http://127.0.0.1:2024

# --- FRONTEND (Next.js) ---
# Prefixed with NEXT_PUBLIC_ to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
# The public-facing URL of your Backend
NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:5000

# --- ASSISTANT (LangGraph) ---
# Options: openai, anthropic, google_genai, etc.
ASSISTANT_MODEL_PROVIDER=openai
# Examples: gpt-4o, claude-3-5-sonnet-20240620
ASSISTANT_MODEL_NAME=gpt-4o
ASSISTANT_MODEL_API_KEY=sk-your-llm-api-key

# --- DEPLOYMENT (Can delete if only running locally) ---
DOCKER_USERNAME=your-docker-username
# The port where the Quart Backend will be accessible on your host machine.
# Change this if port 5000 is already in use.
# Internal Docker port is fixed at 5000.
BACKEND_PORT=5000
# The port where the Assistant will be accessible on your host machine.
# Change this if port 8123 is already in use on your system.
# Internal Docker port is fixed at 8000.
ASSISTANT_PORT=8123
# Langsmith api key required to run the assistant in deployment (unnecessary for local dev)
LANGSMITH_API_KEY